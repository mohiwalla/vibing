{
	"useTabs": true,
	"tabWidth": 4,
	"semi": false,
	"singleQuote": false,
	"trailingComma": "es5",
	"endOfLine": "lf",
	"printWidth": 80,
	"arrowParens": "always",
	"quoteProps": "as-needed",
	"bracketSpacing": true,
	"bracketSameLine": false,
	"overrides": [
		{
			"files": ["*.yml", "*.yaml", "*.md"],
			"options": {
				"useTabs": false,
				"tabWidth": 2
			}
		}
	]
}
